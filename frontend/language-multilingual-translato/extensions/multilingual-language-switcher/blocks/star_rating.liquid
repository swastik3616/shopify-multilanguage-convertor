<div class="language-switcher">
  <select id="translator-language">
    <option value="en">English</option>
    <option value="fr">French</option>
    <option value="de">German</option>
    <option value="es">Spanish</option>
    <option value="hi">Hindi</option>
  </select>
</div>

<style>
.language-switcher{
  position:fixed;
  top:20px;
  right:20px;
  z-index:9999;
}

#translator-language{
  padding:10px;
  border-radius:8px;
  border:1px solid #ddd;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const languageSelector = document.getElementById('translator-language');

  languageSelector.addEventListener('change', async function() {
    const selectedLanguage = this.value;
    console.log('Selected Language:', selectedLanguage);

    // 1. Get all text elements you want to translate
    const textElements = document.querySelectorAll('p, h1, h2, h3, h4, h5, h6, span, a');
    const elementsToTranslate = [];
    const textsToTranslate = [];

    // 2. Loop through each element and collect the text
    for (let i = 0; i < textElements.length; i++) {
      const el = textElements[i];
      const originalText = el.innerText.trim();
      
      // Skip empty strings and elements that have nested HTML tags to avoid breaking layout
      if (!originalText || el.children.length > 0) continue;

      elementsToTranslate.push(el);
      textsToTranslate.push(originalText);
    }

    if (textsToTranslate.length === 0) return;

    try {
      console.log(`Translating ${textsToTranslate.length} elements to ${selectedLanguage}...`);
      
      // 3. Send ONE request to the bulk-translate backend
      const response = await fetch("https://shopify-multilanguage-convertor.onrender.com/bulk-translate", {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          texts: textsToTranslate,
          target_language: selectedLanguage
        })
      });

      const data = await response.json();
      
      // 4. Update the website text with the response
      if (data.translations && data.translations.length === textsToTranslate.length) {
        for (let i = 0; i < elementsToTranslate.length; i++) {
          elementsToTranslate[i].innerText = data.translations[i];
        }
        console.log("Translation complete!");
      } else {
        console.error("Translation failed: ", data.message || "Invalid response format.");
      }
    } catch (error) {
      console.error("Bulk translation network error:", error);
    }
  });
});
</script>

{% schema %}
{
  "name": "Language Switcher",
  "target": "section",
  "settings": []
}
{% endschema %}