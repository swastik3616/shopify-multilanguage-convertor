<div class="lang-switcher-wrapper" id="lang-switcher-wrapper">
  <button class="lang-switcher-btn" id="lang-switcher-btn" aria-label="Change language">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span id="lang-current-label">English</span>
    <svg class="lang-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>

  <div class="lang-dropdown" id="lang-dropdown" hidden>
    <div class="lang-option" data-value="English">🇺🇸 English</div>
    <div class="lang-option" data-value="French">🇫🇷 French</div>
    <div class="lang-option" data-value="German">🇩🇪 German</div>
    <div class="lang-option" data-value="Spanish">🇪🇸 Spanish</div>
    <div class="lang-option" data-value="Hindi">🇮🇳 Hindi</div>
    <div class="lang-option" data-value="Arabic">🇸🇦 Arabic</div>
    <div class="lang-option" data-value="Japanese">🇯🇵 Japanese</div>
    <div class="lang-option" data-value="Portuguese">🇧🇷 Portuguese</div>
  </div>

  <!-- Loading overlay -->
  <div class="lang-loading-overlay" id="lang-loading-overlay" hidden>
    <div class="lang-loading-box">
      <div class="lang-spinner"></div>
      <p id="lang-loading-text">Translating page…</p>
    </div>
  </div>

  <!-- Toast notification -->
  <div class="lang-toast" id="lang-toast" hidden></div>
</div>

<style>
  /* ── Wrapper ── */
  .lang-switcher-wrapper {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 99999;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* ── Toggle button ── */
  .lang-switcher-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: #1a1a2e;
    color: #fff;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    white-space: nowrap;
  }
  .lang-switcher-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.4);
    background: #16213e;
  }
  .lang-switcher-btn:active { transform: scale(0.97); }

  .lang-chevron {
    transition: transform 0.2s ease;
  }
  .lang-switcher-btn[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown ── */
  .lang-dropdown {
    position: absolute;
    bottom: calc(100% + 10px);
    right: 0;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    overflow: hidden;
    min-width: 180px;
    animation: langDropIn 0.18s ease;
  }
  @keyframes langDropIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lang-option {
    padding: 11px 18px;
    cursor: pointer;
    font-size: 14px;
    color: #222;
    transition: background 0.15s;
  }
  .lang-option:hover { background: #f3f4f6; }
  .lang-option.active { background: #e8f4ff; font-weight: 700; color: #0057b8; }

  /* ── Loading overlay ── */
  .lang-loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999998;
    backdrop-filter: blur(2px);
  }
  .lang-loading-box {
    background: #fff;
    border-radius: 16px;
    padding: 32px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.2);
  }
  .lang-loading-box p {
    margin: 0;
    font-size: 15px;
    color: #333;
    font-weight: 600;
  }
  .lang-spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #e5e7eb;
    border-top-color: #1a1a2e;
    border-radius: 50%;
    animation: langSpin 0.75s linear infinite;
  }
  @keyframes langSpin { to { transform: rotate(360deg); } }

  /* ── Toast ── */
  .lang-toast {
    position: fixed;
    bottom: 90px;
    right: 24px;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    z-index: 999999;
    animation: langToastIn 0.25s ease;
  }
  @keyframes langToastIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .lang-toast.success { background: #16a34a; }
  .lang-toast.error   { background: #dc2626; }
  .lang-toast.warning { background: #d97706; }
</style>

<script>
(function () {
  const BACKEND_URL = 'https://shopify-multilanguage-convertor.onrender.com/bulk-translate';
  const STORAGE_KEY = 'shopify_selected_language';
  const BATCH_SIZE  = 80;
  const TIMEOUT_MS  = 55000; // 55s — tolerates Render cold-start (up to ~50s)

  // ── DOM refs ──
  const wrapper     = document.getElementById('lang-switcher-wrapper');
  const btn         = document.getElementById('lang-switcher-btn');
  const dropdown    = document.getElementById('lang-dropdown');
  const currentLbl  = document.getElementById('lang-current-label');
  const overlay     = document.getElementById('lang-loading-overlay');
  const loadingText = document.getElementById('lang-loading-text');
  const toast       = document.getElementById('lang-toast');
  const options     = document.querySelectorAll('.lang-option');

  // ── Helpers ──
  function showToast(msg, type = 'success', ms = 3500) {
    toast.textContent = msg;
    toast.className   = `lang-toast ${type}`;
    toast.hidden      = false;
    setTimeout(() => { toast.hidden = true; }, ms);
  }

  function setLoading(active, msg = 'Translating page…') {
    overlay.hidden    = !active;
    loadingText.textContent = msg;
    btn.disabled      = active;
  }

  function markActive(language) {
    options.forEach(o => {
      o.classList.toggle('active', o.dataset.value === language);
    });
    currentLbl.textContent = language;
    localStorage.setItem(STORAGE_KEY, language);
  }

  // ── Dropdown toggle ──
  btn.addEventListener('click', function () {
    const open = !dropdown.hidden;
    dropdown.hidden = open;
    btn.setAttribute('aria-expanded', String(!open));
  });

  document.addEventListener('click', function (e) {
    if (!wrapper.contains(e.target)) {
      dropdown.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
    }
  });

  // ── Fetch with timeout ──
  async function fetchWithTimeout(url, options, ms) {
    const ctrl = new AbortController();
    const tid  = setTimeout(() => ctrl.abort(), ms);
    try {
      const res = await fetch(url, { ...options, signal: ctrl.signal });
      clearTimeout(tid);
      return res;
    } catch (err) {
      clearTimeout(tid);
      throw err;
    }
  }

  // ── Core translation ──
  async function translatePage(targetLanguage) {
    // Collect all visible text nodes (recursive TreeWalker)
    const walker = document.createTreeWalker(
      document.body,
      NodeFilter.SHOW_TEXT,
      {
        acceptNode(node) {
          const tag = node.parentElement && node.parentElement.tagName;
          const text = node.nodeValue.trim();
          if (!text) return NodeFilter.FILTER_REJECT;
          if (['SCRIPT','STYLE','NOSCRIPT','TEMPLATE'].includes(tag)) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      }
    );

    const nodes = [], texts = [];
    let node;
    while ((node = walker.nextNode())) {
      nodes.push(node);
      texts.push(node.nodeValue.trim());
    }

    if (texts.length === 0) {
      showToast('No text found on this page.', 'warning');
      return;
    }

    const totalBatches = Math.ceil(texts.length / BATCH_SIZE);
    console.log(`[LangSwitcher] Translating ${texts.length} nodes to "${targetLanguage}" in ${totalBatches} batch(es).`);

    for (let i = 0; i < texts.length; i += BATCH_SIZE) {
      const batchIdx   = Math.floor(i / BATCH_SIZE) + 1;
      const batchTexts = texts.slice(i, i + BATCH_SIZE);
      const batchNodes = nodes.slice(i, i + BATCH_SIZE);

      loadingText.textContent = `Translating… batch ${batchIdx} / ${totalBatches}`;

      try {
        const res = await fetchWithTimeout(
          BACKEND_URL,
          {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({ texts: batchTexts, target_language: targetLanguage })
          },
          TIMEOUT_MS
        );

        if (!res.ok) {
          const err = await res.text();
          console.error(`[LangSwitcher] Batch ${batchIdx} HTTP ${res.status}:`, err);
          showToast(`Translation error (${res.status}). Check API key or provider.`, 'error', 5000);
          return;
        }

        const data = await res.json();

        if (data.translations && data.translations.length === batchTexts.length) {
          batchNodes.forEach((n, j) => { n.nodeValue = data.translations[j]; });
          console.log(`[LangSwitcher] Batch ${batchIdx}/${totalBatches} done.`);
        } else {
          console.error(`[LangSwitcher] Batch ${batchIdx} bad response:`, data);
          showToast('Unexpected response from server. Some text may not be translated.', 'warning', 5000);
        }

      } catch (err) {
        if (err.name === 'AbortError') {
          console.error('[LangSwitcher] Request timed out. Backend may be waking up — try again in 30s.');
          showToast('Server is waking up (cold start). Please wait 30s and try again.', 'warning', 7000);
        } else {
          console.error('[LangSwitcher] Network error:', err);
          showToast('Network error. Check your internet connection.', 'error', 5000);
        }
        return;
      }
    }

    showToast(`Page translated to ${targetLanguage} ✓`, 'success');
  }

  // ── Option click handler ──
  options.forEach(function (opt) {
    opt.addEventListener('click', async function () {
      const lang = opt.dataset.value;
      dropdown.hidden = true;
      btn.setAttribute('aria-expanded', 'false');

      if (lang === 'English') {
        // Reload the page to restore the original English content
        markActive('English');
        localStorage.removeItem(STORAGE_KEY);
        location.reload();
        return;
      }

      markActive(lang);
      setLoading(true, 'Warming up server…');

      try {
        // Pre-warm the Render instance (handles cold-start delay)
        try {
          await fetchWithTimeout(
            'https://shopify-multilanguage-convertor.onrender.com/wake',
            { method: 'GET' },
            55000
          );
        } catch (_) { /* ignore — proceed anyway */ }

        setLoading(true, `Translating page to ${lang}…`);
        await translatePage(lang);
      } finally {
        setLoading(false);
      }
    });
  });

  // ── Auto-restore saved language on page load ──
  // IMPORTANT: Liquid blocks inject AFTER DOMContentLoaded fires.
  // Must check readyState first, otherwise the listener never runs.
  async function autoRestoreLanguage() {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved && saved !== 'English') {
      markActive(saved);
      setLoading(true, `Restoring ${saved} translation…`);
      try {
        await translatePage(saved);
      } finally {
        setLoading(false);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', autoRestoreLanguage);
  } else {
    // DOM already parsed — run immediately (this is the normal case for Liquid blocks)
    autoRestoreLanguage();
  }

})();
</script>

{% schema %}
{
  "name": "Language Switcher",
  "target": "section",
  "settings": []
}
{% endschema %}