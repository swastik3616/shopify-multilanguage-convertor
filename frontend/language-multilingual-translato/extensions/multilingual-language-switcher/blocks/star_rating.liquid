<div class="language-switcher">
  <select id="translator-language">
    <option value="English">English</option>
    <option value="French">French</option>
    <option value="German">German</option>
    <option value="Spanish">Spanish</option>
    <option value="Hindi">Hindi</option>
  </select>
</div>

<style>
.language-switcher{
  position:fixed;
  top:20px;
  right:20px;
  z-index:9999;
}

#translator-language{
  padding:10px;
  border-radius:8px;
  border:1px solid #ddd;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const languageSelector = document.getElementById('translator-language');

  languageSelector.addEventListener('change', async function() {
    const selectedLanguage = this.value;
    console.log('Selected Language:', selectedLanguage);

    // 1. TreeWalker to get ALL raw text nodes on the page (catches carts, dropdowns, buttons, etc.)
    const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null, false);
    const textNodesToTranslate = [];
    const textsToTranslate = [];

    let node;
    while ((node = walker.nextNode())) {
      const text = node.nodeValue.trim();
      const parentTag = node.parentElement ? node.parentElement.tagName : '';
      
      // Skip empty text and ignore script/style/noscript content
      if (text && !['SCRIPT', 'STYLE', 'NOSCRIPT'].includes(parentTag)) {
        textNodesToTranslate.push(node);
        textsToTranslate.push(text);
      }
    }

    if (textsToTranslate.length === 0) return;

    // 2. Batch the requests to safely translate massive pages without hitting LLM token limits
    const BATCH_SIZE = 100;
    console.log(`Translating ${textsToTranslate.length} total text elements to ${selectedLanguage} in batches of ${BATCH_SIZE}...`);

    for (let i = 0; i < textsToTranslate.length; i += BATCH_SIZE) {
      const batchTexts = textsToTranslate.slice(i, i + BATCH_SIZE);
      const batchNodes = textNodesToTranslate.slice(i, i + BATCH_SIZE);
      const batchNumber = Math.floor(i / BATCH_SIZE) + 1;

      try {
        const response = await fetch("https://shopify-multilanguage-convertor.onrender.com/bulk-translate", {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            texts: batchTexts,
            target_language: selectedLanguage
          })
        });

        const data = await response.json();
        
        // 4. Update the actual TextNode values safely without breaking HTML structure
        if (data.translations && data.translations.length === batchTexts.length) {
          for (let j = 0; j < batchNodes.length; j++) {
            batchNodes[j].nodeValue = data.translations[j];
          }
          console.log(`Batch ${batchNumber} complete!`);
        } else {
          console.error(`Translation failed for batch ${batchNumber}: `, data.message || "Invalid response format.");
        }
      } catch (error) {
        console.error(`Bulk translation network error on batch ${batchNumber}:`, error);
      }
    }
    console.log("Total page translation complete!");
  });
});
</script>

{% schema %}
{
  "name": "Language Switcher",
  "target": "section",
  "settings": []
}
{% endschema %}