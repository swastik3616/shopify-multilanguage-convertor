<div id="lsw" style="position:fixed;bottom:24px;right:24px;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
  
 
  <button id="lsw-btn" 
  style="display:flex;align-items:center;gap:8px;padding:12px 20px;
  background:linear-gradient(135deg,#1a1a2e,#16213e);
  color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:14px;font-weight:600;
  box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.2s ease;">
    <svg width="16" height="16" 
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" 
    cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 
    10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    <span id="lsw-label">English</span>
    <svg id="lsw-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform 0.2s ease;"><polyline points="6 9 12 15 18 9"/></svg>
  </button>

  <!-- Dropdown -->
  <div id="lsw-dropdown" hidden style="position:absolute;
  bottom:calc(100% + 12px);right:0;background:#fff;border-radius:16px;
  box-shadow:0 8px 40px rgba(0,0,0,0.15);overflow:hidden;min-width:200px;
  border:1px solid rgba(0,0,0,0.06);">
    <div style="padding:12px 16px;background:#f8f9fa;border-bottom:1px solid #eee;
    font-size:11px;font-weight:700;color:#888;letter-spacing:0.08em;text-transform:uppercase;">Select Language</div>
    <div id="lsw-options"></div>
  </div>

  <!-- Status bar -->
  <div id="lsw-status" hidden style="position:fixed;bottom:80px;right:24px;
  background:linear-gradient(135deg,#1a1a2e,#16213e);color:#fff;padding:12px 20px;border-radius:12px;
  font-size:13px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,0.2);display:flex;
  align-items:center;gap:10px;min-width:200px;z-index:99999;">
    <div id="lsw-spinner" style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);
    border-top-color:#fff;border-radius:50%;animation:lswSpin 0.75s linear infinite;flex-shrink:0;"></div>
    <span id="lsw-status-text">Translating...</span>
  </div>

</div>

<style>
  @keyframes lswSpin { to { transform: rotate(360deg); } }
  #lsw-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
  #lsw-btn:active { transform: scale(0.97); }
  .lsw-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    cursor: pointer;
    font-size: 14px;
    color: #222;
    transition: background 0.15s;
    border-bottom: 1px solid #f0f0f0;
  }
  .lsw-opt:last-child { border-bottom: none; }
  .lsw-opt:hover { background: #f3f4f6; }
  .lsw-opt.active { background: #eef4ff; color: #0057b8; font-weight: 600; }
  .lsw-opt-flag { font-size: 18px; }
  .lsw-opt-name { flex: 1; }
  .lsw-opt-check { color: #0057b8; font-size: 16px; display: none; }
  .lsw-opt.active .lsw-opt-check { display: block; }
</style>

<script>
(async function() {
  const BACKEND = 'https://shopify-multilanguage-convertor.onrender.com';
  const STORAGE_KEY = 'shopify_selected_language';

  const ALL_LANGUAGES = [
    { lang: 'English',    flag: '🇺🇸' },
    { lang: 'French',     flag: '🇫🇷' },
    { lang: 'German',     flag: '🇩🇪' },
    { lang: 'Spanish',    flag: '🇪🇸' },
    { lang: 'Hindi',      flag: '🇮🇳' },
    { lang: 'Arabic',     flag: '🇸🇦' },
    { lang: 'Japanese',   flag: '🇯🇵' },
    { lang: 'Portuguese', flag: '🇧🇷' },
    { lang: 'Marathi',    flag: '🇮🇳' },
    { lang: 'Italian',    flag: '🇮🇹' },
    { lang: 'Chinese',    flag: '🇨🇳' },
    { lang: 'Korean',     flag: '🇰🇷' }
  ];

  const btn      = document.getElementById('lsw-btn');
  const dropdown = document.getElementById('lsw-dropdown');
  const label    = document.getElementById('lsw-label');
  const chevron  = document.getElementById('lsw-chevron');
  const status   = document.getElementById('lsw-status');
  const statusTxt = document.getElementById('lsw-status-text');
  const optCont  = document.getElementById('lsw-options');

  let activeLanguages = ALL_LANGUAGES;

  try {
    const res = await fetch(`${BACKEND}/get-languages`);
    if (res.ok) {
      const data = await res.json();
      const selectedLangs = [data.source, ...(data.targets || [])].filter(Boolean);
      if (selectedLangs.length > 0) {
        activeLanguages = ALL_LANGUAGES.filter(item => selectedLangs.includes(item.lang));
      }
    }
  } catch (e) {
    console.error('[LSW] Failed to fetch configured languages:', e);
  }

  // Build dropdown
  activeLanguages.forEach(function(item) {
    const el = document.createElement('div');
    el.className = 'lsw-opt';
    el.dataset.lang = item.lang;
    el.innerHTML = `
      <span class="lsw-opt-flag">${item.flag}</span>
      <span class="lsw-opt-name">${item.lang}</span>
      <span class="lsw-opt-check">✓</span>
    `;
    el.addEventListener('click', function(e) {
      e.stopPropagation();
      handleSelect(item.lang);
    });
    optCont.appendChild(el);
  });

  // Toggle dropdown
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    const open = !dropdown.hidden;
    dropdown.hidden = open;
    chevron.style.transform = open ? '' : 'rotate(180deg)';
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#lsw')) {
      dropdown.hidden = true;
      chevron.style.transform = '';
    }
  });

  function setActive(lang) {
    document.querySelectorAll('.lsw-opt').forEach(function(o) {
      o.classList.toggle('active', o.dataset.lang === lang);
    });
    label.textContent = lang;
  }

  async function handleSelect(lang) {
    dropdown.hidden = true;
    chevron.style.transform = '';

    if (lang === 'English') {
      localStorage.removeItem(STORAGE_KEY);
      setActive('English');
      location.reload();
      return;
    }

    setActive(lang);
    localStorage.setItem(STORAGE_KEY, lang);
    await runTranslation(lang);
  }

  async function runTranslation(lang) {
    const walker = document.createTreeWalker(
      document.body, NodeFilter.SHOW_TEXT,
      { acceptNode(n) {
        const tag = n.parentElement && n.parentElement.tagName;
        if (!n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
        if (['SCRIPT','STYLE','NOSCRIPT','TEMPLATE'].includes(tag)) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }}
    );

    const nodes = [], texts = [];
    let n;
    while ((n = walker.nextNode())) { nodes.push(n); texts.push(n.nodeValue.trim()); }

    console.log(`[LSW] Translating ${texts.length} nodes to ${lang}`);
    status.hidden = false;
    statusTxt.textContent = `Translating...`;

    try {
      const res = await fetch(`${BACKEND}/bulk-translate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: texts, target_language: lang })
      });
      if (res.ok) {
        const data = await res.json();
        const translations = data.translations;
        for (let i = 0; i < nodes.length; i++) {
          if (translations && translations[i]) {
            nodes[i].nodeValue = translations[i];
          }
        }
      }
    } catch(e) {
      console.error(`[LSW] Bulk translation failed:`, e);
    }

    status.hidden = true;
    statusTxt.textContent = 'Translating...';
    console.log('[LSW] Done!');
  }

  // Auto restore saved language
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved && saved !== 'English') {
    setActive(saved);
    runTranslation(saved);
  } else {
    setActive('English');
  }

})();
</script>

{% schema %}
{
  "name": "Language Switcher",
  "target": "body",
  "settings": []
}
{% endschema %}