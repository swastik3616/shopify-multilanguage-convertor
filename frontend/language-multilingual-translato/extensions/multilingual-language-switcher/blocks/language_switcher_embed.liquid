<div id="lsw-container" translate="no" class="notranslate" style="position:fixed;bottom:24px;right:24px;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;display:flex;gap:12px;align-items:flex-end;">
  
  <!-- Currency Toggle -->
  <div id="lsw-curr-embed" style="position:relative;display:none;">
    <button id="lsw-curr-btn" 
    style="display:flex;align-items:center;gap:8px;padding:12px 20px;
    background:linear-gradient(135deg,#1a1a2e,#16213e);
    color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:14px;font-weight:600;
    box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.2s ease;">
      <span style="font-size:16px;">💲</span>
      <span id="lsw-curr-label">USD</span>
      <svg id="lsw-curr-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform 0.2s ease;"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div id="lsw-curr-dropdown" hidden style="position:absolute;
    bottom:calc(100% + 12px);right:0;background:#fff;border-radius:16px;
    box-shadow:0 8px 40px rgba(0,0,0,0.15);overflow:hidden;min-width:120px;
    border:1px solid rgba(0,0,0,0.06);">
      <div style="padding:12px 16px;background:#f8f9fa;border-bottom:1px solid #eee;
      font-size:11px;font-weight:700;color:#888;letter-spacing:0.08em;text-transform:uppercase;">Select Currency</div>
      <div id="lsw-curr-options"></div>
    </div>
  </div>

  <!-- Language Toggle -->
  <div id="lsw-embed" style="position:relative;">
    <button id="lsw-embed-btn" 
    style="display:flex;align-items:center;gap:8px;padding:12px 20px;
    background:linear-gradient(135deg,#1a1a2e,#16213e);
    color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:14px;font-weight:600;
    box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.2s ease;">
      <svg width="16" height="16" 
      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" 
      cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 
      10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <span id="lsw-embed-label">Loading...</span>
      <svg id="lsw-embed-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform 0.2s ease;"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div id="lsw-embed-dropdown" hidden style="position:absolute;
    bottom:calc(100% + 12px);right:0;background:#fff;border-radius:16px;
    box-shadow:0 8px 40px rgba(0,0,0,0.15);overflow:hidden;min-width:200px;
    border:1px solid rgba(0,0,0,0.06);">
      <div style="padding:12px 16px;background:#f8f9fa;border-bottom:1px solid #eee;
      font-size:11px;font-weight:700;color:#888;letter-spacing:0.08em;text-transform:uppercase;">Select Language</div>
      <div id="lsw-embed-options"></div>
    </div>
  </div>

  <!-- Status bar -->
  <div id="lsw-embed-status" hidden style="position:fixed;bottom:80px;right:24px;
  background:linear-gradient(135deg,#1a1a2e,#16213e);color:#fff;padding:12px 20px;border-radius:12px;
  font-size:13px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,0.2);display:none;
  align-items:center;gap:10px;min-width:200px;z-index:99999;">
    <div id="lsw-embed-spinner" style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);
    border-top-color:#fff;border-radius:50%;animation:lswSpin 0.75s linear infinite;flex-shrink:0;"></div>
    <span id="lsw-embed-status-text">Translating...</span>
  </div>
</div>

<style>
  @keyframes lswSpin { to { transform: rotate(360deg); } }
  #lsw-embed-btn:hover, #lsw-curr-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
  #lsw-embed-btn:active, #lsw-curr-btn:active { transform: scale(0.97); }

  .lsw-embed-opt, .lsw-curr-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    cursor: pointer;
    font-size: 14px;
    color: #222;
    transition: background 0.15s;
    border-bottom: 1px solid #f0f0f0;
  }
  .lsw-embed-opt:last-child, .lsw-curr-opt:last-child { border-bottom: none; }
  .lsw-embed-opt:hover, .lsw-curr-opt:hover { background: #f3f4f6; }
  .lsw-embed-opt.active, .lsw-curr-opt.active { background: #eef4ff; color: #0057b8; font-weight: 600; }
  .lsw-embed-opt-flag { font-size: 18px; }
  .lsw-embed-opt-name, .lsw-curr-opt-name { flex: 1; }
  .lsw-embed-opt-check, .lsw-curr-opt-check { color: #0057b8; font-size: 16px; display: none; }
  .lsw-embed-opt.active .lsw-embed-opt-check, .lsw-curr-opt.active .lsw-curr-opt-check { display: block; }
</style>

<script>
(async function() {
  const BACKEND = 'https://shopify-multilanguage-convertor.onrender.com';
  const STORAGE_KEY = 'shopify_selected_language';
  const CURRENCY_STORAGE_KEY = 'shopify_selected_currency';

  function getBadge(code) {
    const map = {
      'en': '🇺🇸', 'fr': '🇫🇷', 'de': '🇩🇪', 'es': '🇪🇸', 'hi': '🇮🇳',
      'ar': '🇸🇦', 'ja': '🇯🇵', 'pt': '🇧🇷', 'mr': '🇮🇳', 'it': '🇮🇹',
      'zh': '🇨🇳', 'ko': '🇰🇷'
    };
    return map[code.toLowerCase()] || code.toUpperCase();
  }

  const btn      = document.getElementById('lsw-embed-btn');
  const dropdown = document.getElementById('lsw-embed-dropdown');
  const lswRoot  = document.getElementById('lsw-container');
  const label    = document.getElementById('lsw-embed-label');
  const chevron  = document.getElementById('lsw-embed-chevron');
  const status   = document.getElementById('lsw-embed-status');
  const statusTxt = document.getElementById('lsw-embed-status-text');
  const optCont  = document.getElementById('lsw-embed-options');

  const currBtn      = document.getElementById('lsw-curr-btn');
  const currDropdown = document.getElementById('lsw-curr-dropdown');
  const currLabel    = document.getElementById('lsw-curr-label');
  const currChevron  = document.getElementById('lsw-curr-chevron');
  const currOptCont  = document.getElementById('lsw-curr-options');
  const currEmbed    = document.getElementById('lsw-curr-embed');

  let sourceLanguage = 'English';
  let activeLanguages = [];

  let currencyEnabled = false;
  let currencyApiKey = "";
  const baseCurrency = (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'USD';
  
  const supportedCurrencies = [
    { code: 'AED', symbol: 'د.إ' },
    { code: 'AFN', symbol: '؋' },
    { code: 'ALL', symbol: 'L' },
    { code: 'AMD', symbol: '֏' },
    { code: 'ANG', symbol: 'ƒ' },
    { code: 'AOA', symbol: 'Kz' },
    { code: 'ARS', symbol: '$' },
    { code: 'AUD', symbol: '$' },
    { code: 'AWG', symbol: 'ƒ' },
    { code: 'AZN', symbol: '₼' },
    { code: 'BAM', symbol: 'KM' },
    { code: 'BBD', symbol: '$' },
    { code: 'BDT', symbol: '৳' },
    { code: 'BGN', symbol: 'лв' },
    { code: 'BHD', symbol: '.د.ب' },
    { code: 'BIF', symbol: 'FBu' },
    { code: 'BMD', symbol: '$' },
    { code: 'BND', symbol: '$' },
    { code: 'BOB', symbol: 'Bs.' },
    { code: 'BRL', symbol: 'R$' },
    { code: 'BSD', symbol: '$' },
    { code: 'BTN', symbol: 'Nu.' },
    { code: 'BWP', symbol: 'P' },
    { code: 'BYN', symbol: 'Br' },
    { code: 'BZD', symbol: 'BZ$' },
    { code: 'CAD', symbol: '$' },
    { code: 'CDF', symbol: 'FC' },
    { code: 'CHF', symbol: 'CHF' },
    { code: 'CLP', symbol: '$' },
    { code: 'CNY', symbol: '¥' },
    { code: 'COP', symbol: '$' },
    { code: 'CRC', symbol: '₡' },
    { code: 'CUP', symbol: '$' },
    { code: 'CVE', symbol: '$' },
    { code: 'CZK', symbol: 'Kč' },
    { code: 'DJF', symbol: 'Fdj' },
    { code: 'DKK', symbol: 'kr' },
    { code: 'DOP', symbol: 'RD$' },
    { code: 'DZD', symbol: 'د.ج' },
    { code: 'EGP', symbol: '£' },
    { code: 'ERN', symbol: 'Nfk' },
    { code: 'ETB', symbol: 'Br' },
    { code: 'EUR', symbol: '€' },
    { code: 'FJD', symbol: '$' },
    { code: 'FKP', symbol: '£' },
    { code: 'GBP', symbol: '£' },
    { code: 'GEL', symbol: '₾' },
    { code: 'GHS', symbol: 'GH₵' },
    { code: 'GIP', symbol: '£' },
    { code: 'GMD', symbol: 'D' },
    { code: 'GNF', symbol: 'FG' },
    { code: 'GTQ', symbol: 'Q' },
    { code: 'GYD', symbol: '$' },
    { code: 'HKD', symbol: '$' },
    { code: 'HNL', symbol: 'L' },
    { code: 'HTG', symbol: 'G' },
    { code: 'HUF', symbol: 'Ft' },
    { code: 'IDR', symbol: 'Rp' },
    { code: 'ILS', symbol: '₪' },
    { code: 'INR', symbol: '₹' },
    { code: 'IQD', symbol: 'ع.د' },
    { code: 'IRR', symbol: '﷼' },
    { code: 'ISK', symbol: 'kr' },
    { code: 'JMD', symbol: 'J$' },
    { code: 'JOD', symbol: 'د.ا' },
    { code: 'JPY', symbol: '¥' },
    { code: 'KES', symbol: 'KSh' },
    { code: 'KGS', symbol: 'лв' },
    { code: 'KHR', symbol: '៛' },
    { code: 'KMF', symbol: 'CF' },
    { code: 'KRW', symbol: '₩' },
    { code: 'KWD', symbol: 'د.ك' },
    { code: 'KYD', symbol: '$' },
    { code: 'KZT', symbol: '₸' },
    { code: 'LAK', symbol: '₭' },
    { code: 'LBP', symbol: '£' },
    { code: 'LKR', symbol: '₨' },
    { code: 'LRD', symbol: '$' },
    { code: 'LSL', symbol: 'L' },
    { code: 'LYD', symbol: 'ل.د' },
    { code: 'MAD', symbol: 'د.م.' },
    { code: 'MDL', symbol: 'L' },
    { code: 'MGA', symbol: 'Ar' },
    { code: 'MKD', symbol: 'ден' },
    { code: 'MMK', symbol: 'K' },
    { code: 'MNT', symbol: '₮' },
    { code: 'MOP', symbol: 'P' },
    { code: 'MRU', symbol: 'UM' },
    { code: 'MUR', symbol: '₨' },
    { code: 'MVR', symbol: 'MVR' },
    { code: 'MWK', symbol: 'MK' },
    { code: 'MXN', symbol: '$' },
    { code: 'MYR', symbol: 'RM' },
    { code: 'MZN', symbol: 'MT' },
    { code: 'NAD', symbol: '$' },
    { code: 'NGN', symbol: '₦' },
    { code: 'NIO', symbol: 'C$' },
    { code: 'NOK', symbol: 'kr' },
    { code: 'NPR', symbol: '₨' },
    { code: 'NZD', symbol: '$' },
    { code: 'OMR', symbol: 'ر.ع.' },
    { code: 'PAB', symbol: 'B/.' },
    { code: 'PEN', symbol: 'S/.' },
    { code: 'PGK', symbol: 'K' },
    { code: 'PHP', symbol: '₱' },
    { code: 'PKR', symbol: '₨' },
    { code: 'PLN', symbol: 'zł' },
    { code: 'PYG', symbol: 'Gs' },
    { code: 'QAR', symbol: 'ر.ق' },
    { code: 'RON', symbol: 'lei' },
    { code: 'RSD', symbol: 'Дин.' },
    { code: 'RUB', symbol: '₽' },
    { code: 'RWF', symbol: 'FRw' },
    { code: 'SAR', symbol: 'ر.س' },
    { code: 'SBD', symbol: '$' },
    { code: 'SCR', symbol: '₨' },
    { code: 'SDG', symbol: '£' },
    { code: 'SEK', symbol: 'kr' },
    { code: 'SGD', symbol: '$' },
    { code: 'SHP', symbol: '£' },
    { code: 'SLL', symbol: 'Le' },
    { code: 'SOS', symbol: 'S' },
    { code: 'SRD', symbol: '$' },
    { code: 'STN', symbol: 'Db' },
    { code: 'SVC', symbol: '₡' },
    { code: 'SYP', symbol: '£' },
    { code: 'SZL', symbol: 'L' },
    { code: 'THB', symbol: '฿' },
    { code: 'TJS', symbol: 'SM' },
    { code: 'TMT', symbol: 'T' },
    { code: 'TND', symbol: 'د.ت' },
    { code: 'TOP', symbol: 'T$' },
    { code: 'TRY', symbol: '₺' },
    { code: 'TTD', symbol: 'TT$' },
    { code: 'TWD', symbol: 'NT$' },
    { code: 'TZS', symbol: 'TSh' },
    { code: 'UAH', symbol: '₴' },
    { code: 'UGX', symbol: 'USh' },
    { code: 'USD', symbol: '$' },
    { code: 'UYU', symbol: '$U' },
    { code: 'UZS', symbol: 'лв' },
    { code: 'VES', symbol: 'Bs.S' },
    { code: 'VND', symbol: '₫' },
    { code: 'VUV', symbol: 'VT' },
    { code: 'WST', symbol: 'WS$' },
    { code: 'XAF', symbol: 'FCFA' },
    { code: 'XCD', symbol: '$' },
    { code: 'XOF', symbol: 'CFA' },
    { code: 'XPF', symbol: '₣' },
    { code: 'YER', symbol: '﷼' },
    { code: 'ZAR', symbol: 'R' },
    { code: 'ZMW', symbol: 'ZK' },
    { code: 'ZWL', symbol: '$' }
  ];
  
  // Make sure base currency is in list
  if (!supportedCurrencies.find(c => c.code === baseCurrency)) {
    supportedCurrencies.unshift({ code: baseCurrency, symbol: baseCurrency + ' ' });
  }

  let activeCurrencyCodes = ['USD', 'EUR', 'GBP', 'INR', 'CAD']; // Default fallback

  try {
    const flagRes = await fetch(`${BACKEND}/get-feature-flags`);
    if (flagRes.ok) {
      const flags = await flagRes.json();
      currencyEnabled = flags.currency_enabled || false;
      currencyApiKey = flags.currency_api_key || "";
      if (flags.active_currencies && Array.isArray(flags.active_currencies)) {
        activeCurrencyCodes = flags.active_currencies;
      }
    }
  } catch (e) {
    console.error('[LSW] Failed to fetch feature flags:', e);
  }

  if (currencyEnabled) {
    currEmbed.style.display = 'block';
    
    // Filter supported currencies down to the ones chosen in settings, plus base currency
    let displayCurrencies = supportedCurrencies.filter(c => activeCurrencyCodes.includes(c.code) || c.code === baseCurrency);
    // Remove duplicates just in case
    displayCurrencies = displayCurrencies.filter((c, index, self) => index === self.findIndex((t) => t.code === c.code));
    
    // Build currency dropdown
    displayCurrencies.forEach(function(item) {
      const el = document.createElement('div');
      el.className = 'lsw-curr-opt';
      el.dataset.curr = item.code;
      el.innerHTML = `
        <span class="lsw-curr-opt-name">${item.code} (${item.symbol})</span>
        <span class="lsw-curr-opt-check">✓</span>
      `;
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        handleCurrencySelect(item.code);
      });
      currOptCont.appendChild(el);
    });
  }

  try {
    const res = await fetch(`${BACKEND}/get-languages?admin=true`);
    if (res.ok) {
      const data = await res.json();
      const sourceObj = data.find(l => l.status === 'Source' || l.status === 'Both');
      if (sourceObj) sourceLanguage = sourceObj.name;
      
      const active = data.filter(l => ['Source', 'Target', 'Both'].includes(l.status));
      if (active.length > 0) {
        activeLanguages = active.map(item => ({
          lang: item.name,
          flag: getBadge(item.code)
        }));
      }
    }
  } catch (e) {
    console.error('[LSW] Failed to fetch configured languages:', e);
  }

  activeLanguages.forEach(function(item) {
    const el = document.createElement('div');
    el.className = 'lsw-embed-opt';
    el.dataset.lang = item.lang;
    el.innerHTML = `
      <span class="lsw-embed-opt-flag">${item.flag}</span>
      <span class="lsw-embed-opt-name">${item.lang}</span>
      <span class="lsw-embed-opt-check">✓</span>
    `;
    el.addEventListener('click', function(e) {
      e.stopPropagation();
      handleSelect(item.lang);
    });
    optCont.appendChild(el);
  });

  // Toggles
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    const open = !dropdown.hidden;
    dropdown.hidden = open;
    chevron.style.transform = open ? '' : 'rotate(180deg)';
    if (open) { currDropdown.hidden = true; currChevron.style.transform = ''; }
  });

  if (currBtn) {
    currBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      const open = !currDropdown.hidden;
      currDropdown.hidden = open;
      currChevron.style.transform = open ? '' : 'rotate(180deg)';
      if (open) { dropdown.hidden = true; chevron.style.transform = ''; }
    });
  }

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#lsw-container')) {
      dropdown.hidden = true;
      chevron.style.transform = '';
      if (currDropdown) {
        currDropdown.hidden = true;
        currChevron.style.transform = '';
      }
    }
  });

  function setActiveLanguage(lang) {
    document.querySelectorAll('.lsw-embed-opt').forEach(function(o) {
      o.classList.toggle('active', o.dataset.lang === lang);
    });
    label.textContent = lang;
  }

  function setActiveCurrency(currCode) {
    document.querySelectorAll('.lsw-curr-opt').forEach(function(o) {
      o.classList.toggle('active', o.dataset.curr === currCode);
    });
    if (currLabel) currLabel.textContent = currCode;
  }

  let syncOverlayReplacements = async function() {};

  async function handleSelect(lang) {
    dropdown.hidden = true;
    chevron.style.transform = '';

    if (lang === sourceLanguage) {
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      setActiveLanguage(sourceLanguage);
      location.reload();
      return;
    }

    setActiveLanguage(lang);
    try { localStorage.setItem(STORAGE_KEY, lang); } catch (e) {}
    await runTranslation(lang);
    await syncOverlayReplacements();
  }

  async function handleCurrencySelect(currCode) {
    if (currDropdown) currDropdown.hidden = true;
    if (currChevron) currChevron.style.transform = '';

    setActiveCurrency(currCode);
    try { localStorage.setItem(CURRENCY_STORAGE_KEY, currCode); } catch (e) {}
    
    if (currCode === baseCurrency) {
       location.reload();
       return;
    }
    
    await runCurrencyConversion(currCode);
  }

  async function runCurrencyConversion(targetCurrency) {
    if (!currencyEnabled || !currencyApiKey) return;
    try {
      const res = await fetch(`https://v6.exchangerate-api.com/v6/${currencyApiKey}/latest/${baseCurrency}`);
      if (res.ok) {
        const data = await res.json();
        const rate = data.conversion_rates[targetCurrency];
        if (rate && targetCurrency !== baseCurrency) {
          const symObj = supportedCurrencies.find(c => c.code === targetCurrency);
          const newSymbol = symObj ? symObj.symbol : targetCurrency + ' ';
          
          const PRICE_SELECTORS = [
            '.money', '.price', '.price-item', '.product__price',
            '.product-price', '[data-product-price]', '[data-regular-price]',
            '[data-sale-price]', '.amount', '.price__regular',
            '.price__sale', '.price__compare', '.price--on-sale',
            '.cart-item__price', '.cart__price', '.order-summary__price',
            'span[class*="price"]', 'span[class*="money"]', 'span[class*="amount"]'
          ].join(', ');

          function applyConversion() {
            if (window.__lswCurrencyApplying) return;
            window.__lswCurrencyApplying = true;
            try {
              const priceEls = document.querySelectorAll(PRICE_SELECTORS);
              const priceElsArray = Array.from(priceEls);
              const dedupedEls = priceElsArray.filter(el =>
                !priceElsArray.some(other => other !== el && other.contains(el))
              );

              dedupedEls.forEach(el => {
                const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
                let node;
                while ((node = walker.nextNode())) {
                  if (node._lswOriginal === undefined) node._lswOriginal = node.nodeValue;
                  const originalNodeText = node._lswOriginal;
                  const match = originalNodeText.match(/([\d,]+(?:\.\d+)?)/);
                  if (match && match[1]) {
                    const numValue = parseFloat(match[1].replace(/,/g, ''));
                    if (!isNaN(numValue) && numValue > 0) {
                      const convertedValue = (numValue * rate).toFixed(2);
                      let newText = originalNodeText.replace(match[1], convertedValue);
                      newText = newText.replace(/[\$€£¥₹₩]|(?:Rs\.?\s*|rs\s*|USD|EUR|GBP|INR|AED|CAD)/ig, '').trim();
                      node.nodeValue = `${newSymbol}${newText}`;
                    }
                  }
                }
              });
            } finally {
              window.__lswCurrencyApplying = false;
            }
          }
          applyConversion();
          window.__lswCurrencyReapply = applyConversion;
        }
      }
    } catch (err) {
      console.error('[LSW] Currency API failed:', err);
    }
  }

  const lswRoot = document.getElementById('lsw-container');

  async function runTranslation(lang) {
    const walker = document.createTreeWalker(
      document.body, NodeFilter.SHOW_TEXT,
      { acceptNode(n) {
        const tag = n.parentElement && n.parentElement.tagName;
        if (!n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
        if (['SCRIPT','STYLE','NOSCRIPT','TEMPLATE'].includes(tag)) return NodeFilter.FILTER_REJECT;
        if (lswRoot && lswRoot.contains(n.parentElement)) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }}
    );

    const nodes = [], texts = [];
    let n;
    while ((n = walker.nextNode())) { 
      nodes.push(n); 
      if (n.__lsw_orig_node_text === undefined) n.__lsw_orig_node_text = n.nodeValue;
      texts.push(n.__lsw_orig_node_text.trim()); 
      let p = n.parentElement;
      while (p && p !== document.documentElement) {
        if (p.__lsw_orig_text !== undefined) break;
        p.__lsw_orig_text = p.textContent;
        p = p.parentElement;
      }
    }

    status.style.display = 'flex';
    statusTxt.textContent = `Translating...`;

    try {
      const res = await fetch(`${BACKEND}/bulk-translate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: texts, target_language: lang })
      });
      if (res.ok) {
        const data = await res.json();
        const translations = data.translations;
        for (let i = 0; i < nodes.length; i++) {
          if (translations && translations[i]) {
            const orig = nodes[i].__lsw_orig_node_text;
            const trimmed = orig.trim();
            if (trimmed) {
              nodes[i].nodeValue = orig.replace(trimmed, translations[i]);
            } else {
              nodes[i].nodeValue = translations[i];
            }
          }
        }
      }
    } catch(e) {}
    status.style.display = 'none';
  }

  // Load saved state
  let savedLang = null;
  let savedCurr = null;
  try { savedLang = localStorage.getItem(STORAGE_KEY); } catch (e) {}
  try { savedCurr = localStorage.getItem(CURRENCY_STORAGE_KEY); } catch (e) {}

  if (savedLang && savedLang !== sourceLanguage) {
    setActiveLanguage(savedLang);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => runTranslation(savedLang));
    } else {
      runTranslation(savedLang);
    }
  } else {
    setActiveLanguage(sourceLanguage);
  }

  if (savedCurr && savedCurr !== baseCurrency && currencyEnabled) {
    setActiveCurrency(savedCurr);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => runCurrencyConversion(savedCurr));
    } else {
      runCurrencyConversion(savedCurr);
    }
  } else {
    setActiveCurrency(baseCurrency);
  }

  // Overlay sync setup...
  if (!window.__multilingualOverlayLoaded) {
    window.__multilingualOverlayLoaded = true;
    const overlayBackend = 'https://shopify-multilanguage-convertor.onrender.com';
    const currentUrl = (window.location.origin + window.location.pathname + window.location.search).replace(/\/$/, '');

    function normalizeText(value) { return (value || '').replace(/\s+/g, ' ').trim(); }

    function matchesTarget(element, originalText, elementTag) {
      if (!originalText) return false;
      const normalizedOriginal = normalizeText(originalText);
      const upperTag = (elementTag || '').toUpperCase();
      const currentText = element.__lsw_orig_text !== undefined ? element.__lsw_orig_text : (element.textContent || '');

      if (['INPUT', 'TEXTAREA'].includes(upperTag)) {
        const candidateText = normalizeText(element.value || element.placeholder || '');
        return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
      }

      if (upperTag === 'BUTTON' || element.tagName === 'BUTTON') {
        const candidateText = normalizeText(element.__lsw_orig_text !== undefined ? element.__lsw_orig_text : (element.textContent || element.value || ''));
        return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
      }

      const candidateText = normalizeText(currentText);
      return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
    }

    function applyTextToElement(element, newText, elementTag) {
      const tag = (element.tagName || elementTag || '').toUpperCase();
      if (tag === 'INPUT' || tag === 'TEXTAREA') {
        if (element.type === 'submit' || element.type === 'button') {
          element.value = newText;
        } else if (element.placeholder && element.placeholder.trim() !== '') {
          element.placeholder = newText;
        } else {
          element.value = newText;
        }
        return;
      }

      const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT, null, false);
      const textNodes = [];
      let n;
      while (n = walker.nextNode()) {
        if (n.nodeValue.trim().length > 0) textNodes.push(n);
      }

      if (textNodes.length > 0) {
        textNodes[0].nodeValue = newText;
        for (let i = 1; i < textNodes.length; i++) textNodes[i].nodeValue = '';
      } else {
        element.appendChild(document.createTextNode(newText));
      }
    }

    function applyReplacements(replacements) {
      if (!Array.isArray(replacements) || !replacements.length) return;
      replacements.forEach(function(item) {
        const originalText = item.original_text;
        const newText = item.new_text;
        const selector = item.selector;
        const elementTag = item.element_tag;

        if (!newText || !selector) return;

        try {
          const matchingElements = Array.from(document.querySelectorAll(selector)).filter(function(el) {
            return matchesTarget(el, originalText, elementTag);
          });
          if (matchingElements.length) {
            matchingElements.forEach(function(el) { applyTextToElement(el, newText, elementTag); });
          }
        } catch(e) {}
      });
    }

    syncOverlayReplacements = async function() {
      try {
        const requestUrl = new URL(`${overlayBackend}/overlay/replacements`);
        requestUrl.searchParams.set('url', currentUrl);

        let selectedLang = null;
        try { selectedLang = localStorage.getItem(STORAGE_KEY); } catch (e) {}
        if (selectedLang && selectedLang !== sourceLanguage) {
          requestUrl.searchParams.set('target_language', selectedLang);
        }

        const res = await fetch(requestUrl.toString());
        if (!res.ok) return;
        const data = await res.json();
        const replacements = Array.isArray(data && data.replacements) ? data.replacements : [];
        if (replacements.length) {
          applyReplacements(replacements);
          if (window.__lswCurrencyReapply) window.__lswCurrencyReapply();
        }
      } catch (e) {}
    };

    syncOverlayReplacements();
    setInterval(syncOverlayReplacements, 5000);
    window.addEventListener('focus', syncOverlayReplacements);
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) syncOverlayReplacements();
    });
    const observer = new MutationObserver(function() {
      syncOverlayReplacements();
    });
    observer.observe(document.body || document.documentElement, { childList: true, subtree: true, characterData: true });
  }

})();
</script>

