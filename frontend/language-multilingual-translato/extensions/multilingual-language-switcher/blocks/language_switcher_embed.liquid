<div id="lsw-embed" translate="no" class="notranslate" style="position:fixed;bottom:24px;right:24px;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
  <!-- Search Panel (above buttons) -->
  <div id="lsw-search-panel" hidden style="position:absolute;bottom:60px;right:0;width:360px;max-height:420px;background:#fff;border-radius:16px;box-shadow:0 8px 40px rgba(0,0,0,0.15);overflow:hidden;border:1px solid rgba(0,0,0,0.06);display:none;flex-direction:column;">
    <div style="padding:12px 16px;border-bottom:1px solid #eee;">
      <div style="display:flex;align-items:center;gap:8px;background:#f3f4f6;border-radius:10px;padding:8px 12px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="lsw-search-input" type="text" placeholder="Search products..." style="border:none;background:transparent;outline:none;flex:1;font-size:14px;color:#222;">
        <span id="lsw-search-lang-badge" style="font-size:11px;background:#e5e7eb;padding:2px 8px;border-radius:12px;color:#555;"></span>
      </div>
    </div>
    <div id="lsw-search-results" style="flex:1;overflow-y:auto;min-height:60px;">
      <div id="lsw-search-empty" style="display:flex;align-items:center;justify-content:center;height:60px;font-size:13px;color:#999;">Type to search</div>
      <div id="lsw-search-loading" style="display:none;align-items:center;justify-content:center;gap:8px;height:60px;font-size:13px;color:#888;">
        <div style="width:14px;height:14px;border:2px solid rgba(0,0,0,0.15);border-top-color:#666;border-radius:50%;animation:lswSpin 0.75s linear infinite;"></div>
        Searching...
      </div>
    </div>
  </div>

  <!-- Buttons row -->
  <div style="display:flex;align-items:center;gap:8px;">
    <button id="lsw-search-btn" style="display:flex;align-items:center;justify-content:center;width:48px;height:48px;background:linear-gradient(135deg,#1a1a2e,#16213e);color:#fff;border:none;border-radius:50%;cursor:pointer;box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.2s ease;" title="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>

    <button id="lsw-embed-btn" 
    style="display:flex;align-items:center;gap:8px;padding:12px 20px;
    background:linear-gradient(135deg,#1a1a2e,#16213e);
    color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:14px;font-weight:600;
    box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.2s ease;">
      <svg width="16" height="16" 
      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" 
      cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 
      10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <span id="lsw-embed-label">Loading...</span>
      <svg id="lsw-embed-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform 0.2s ease;"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
  </div>

  <!-- Dropdown -->
  <div id="lsw-embed-dropdown" hidden style="position:absolute;
  bottom:60px;right:0;background:#fff;border-radius:16px;
  box-shadow:0 8px 40px rgba(0,0,0,0.15);overflow:hidden;min-width:200px;
  border:1px solid rgba(0,0,0,0.06);">
    <div style="padding:12px 16px;background:#f8f9fa;border-bottom:1px solid #eee;
    font-size:11px;font-weight:700;color:#888;letter-spacing:0.08em;text-transform:uppercase;">Select Language</div>
    <div id="lsw-embed-options"></div>
  </div>

  <!-- Status bar -->
  <div id="lsw-embed-status" hidden style="position:fixed;bottom:80px;right:24px;
  background:linear-gradient(135deg,#1a1a2e,#16213e);color:#fff;padding:12px 20px;border-radius:12px;
  font-size:13px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,0.2);display:none;
  align-items:center;gap:10px;min-width:200px;z-index:99999;">
    <div id="lsw-embed-spinner" style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);
    border-top-color:#fff;border-radius:50%;animation:lswSpin 0.75s linear infinite;flex-shrink:0;"></div>
    <span id="lsw-embed-status-text">Translating...</span>
  </div>
</div>

<style>
  @keyframes lswSpin { to { transform: rotate(360deg); } }
  #lsw-embed-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
  #lsw-embed-btn:active { transform: scale(0.97); }
  #lsw-search-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
  #lsw-search-btn:active { transform: scale(0.97); }
  .lsw-search-result {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid #f0f0f0;
  }
  .lsw-search-result:last-child { border-bottom: none; }
  .lsw-search-result:hover { background: #f3f4f6; }
  .lsw-search-result-source {
    font-size: 12px;
    color: #888;
  }
  .lsw-search-result-translated {
    font-size: 14px;
    color: #222;
    font-weight: 500;
  }
  .lsw-search-result-original {
    font-size: 12px;
    color: #999;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .lsw-search-result-fallback {
    font-size: 11px;
    background: #fef3c7;
    color: #92400e;
    padding: 1px 6px;
    border-radius: 8px;
    font-weight: 500;
  }
  .lsw-search-result-lang {
    font-size: 11px;
    background: #d1fae5;
    color: #065f46;
    padding: 1px 6px;
    border-radius: 8px;
    font-weight: 500;
  }
  .lsw-search-result-page {
    font-size: 10px;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .lsw-embed-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    cursor: pointer;
    font-size: 14px;
    color: #222;
    transition: background 0.15s;
    border-bottom: 1px solid #f0f0f0;
  }
  .lsw-embed-opt:last-child { border-bottom: none; }
  .lsw-embed-opt:hover { background: #f3f4f6; }
  .lsw-embed-opt.active { background: #eef4ff; color: #0057b8; font-weight: 600; }
  .lsw-embed-opt-flag { font-size: 18px; }
  .lsw-embed-opt-name { flex: 1; }
  .lsw-embed-opt-check { color: #0057b8; font-size: 16px; display: none; }
  .lsw-embed-opt.active .lsw-embed-opt-check { display: block; }
</style>

<script>
(async function() {
  const BACKEND = 'https://shopify-multilanguage-convertor.onrender.com';
  const STORAGE_KEY = 'shopify_selected_language';

  // Helper to get a flag emoji for common languages, or fallback to the code
  function getBadge(code) {
    const map = {
      'en': '🇺🇸', 'fr': '🇫🇷', 'de': '🇩🇪', 'es': '🇪🇸', 'hi': '🇮🇳',
      'ar': '🇸🇦', 'ja': '🇯🇵', 'pt': '🇧🇷', 'mr': '🇮🇳', 'it': '🇮🇹',
      'zh': '🇨🇳', 'ko': '🇰🇷'
    };
    return map[code.toLowerCase()] || code.toUpperCase();
  }

  const btn      = document.getElementById('lsw-embed-btn');
  const dropdown = document.getElementById('lsw-embed-dropdown');
  const label    = document.getElementById('lsw-embed-label');
  const chevron  = document.getElementById('lsw-embed-chevron');
  const status   = document.getElementById('lsw-embed-status');
  const statusTxt = document.getElementById('lsw-embed-status-text');
  const optCont  = document.getElementById('lsw-embed-options');

  let sourceLanguage = 'English';
  let activeLanguages = [];

  let currencyEnabled = false;
  let currencyApiKey = "";

  try {
    // Fetch feature flags to check if currency is active
    const flagRes = await fetch(`${BACKEND}/get-feature-flags`);
    if (flagRes.ok) {
      const flags = await flagRes.json();
      currencyEnabled = flags.currency_enabled || false;
      currencyApiKey = flags.currency_api_key || "";
    }
  } catch (e) {
    console.error('[LSW] Failed to fetch feature flags:', e);
  }

  try {
    // Fetch directly from the database using the admin parameter
    const res = await fetch(`${BACKEND}/get-languages?admin=true`);
    if (res.ok) {
      const data = await res.json();
      
      const sourceObj = data.find(l => l.status === 'Source' || l.status === 'Both');
      if (sourceObj) {
        sourceLanguage = sourceObj.name;
      }
      
      // Filter out non-selected languages
      const active = data.filter(l => ['Source', 'Target', 'Both'].includes(l.status));
      if (active.length > 0) {
        activeLanguages = active.map(item => ({
          lang: item.name,
          flag: getBadge(item.code)
        }));
      }
    }
  } catch (e) {
    console.error('[LSW] Failed to fetch configured languages:', e);
  }

  // Build dropdown
  activeLanguages.forEach(function(item) {
    const el = document.createElement('div');
    el.className = 'lsw-embed-opt';
    el.dataset.lang = item.lang;
    el.innerHTML = `
      <span class="lsw-embed-opt-flag">${item.flag}</span>
      <span class="lsw-embed-opt-name">${item.lang}</span>
      <span class="lsw-embed-opt-check">✓</span>
    `;
    el.addEventListener('click', function(e) {
      e.stopPropagation();
      handleSelect(item.lang);
    });
    optCont.appendChild(el);
  });

  // Toggle dropdown
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    closeSearch();
    const open = !dropdown.hidden;
    dropdown.hidden = open;
    chevron.style.transform = open ? '' : 'rotate(180deg)';
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#lsw-embed')) {
      dropdown.hidden = true;
      chevron.style.transform = '';
      closeSearch();
    }
  });

  // ── Multilingual Search ──────────────────────────────────────────────────
  const searchBtn = document.getElementById('lsw-search-btn');
  const searchPanel = document.getElementById('lsw-search-panel');
  const searchInput = document.getElementById('lsw-search-input');
  const searchResults = document.getElementById('lsw-search-results');
  const searchEmpty = document.getElementById('lsw-search-empty');
  const searchLoading = document.getElementById('lsw-search-loading');
  const searchLangBadge = document.getElementById('lsw-search-lang-badge');
  let searchTimeout = null;

  function closeSearch() {
    searchPanel.hidden = true;
    searchPanel.style.display = 'none';
  }

  function openSearch() {
    dropdown.hidden = true;
    chevron.style.transform = '';
    searchPanel.hidden = false;
    searchPanel.style.display = 'flex';
    searchInput.focus();
    updateSearchLangBadge();
    if (searchInput.value.trim()) {
      performSearch(searchInput.value.trim());
    }
  }

  function updateSearchLangBadge() {
    const savedLang = localStorage.getItem(STORAGE_KEY);
    if (savedLang && savedLang !== sourceLanguage) {
      searchLangBadge.textContent = savedLang;
    } else {
      searchLangBadge.textContent = sourceLanguage;
    }
  }

  searchBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    if (!searchPanel.hidden) {
      closeSearch();
    } else {
      openSearch();
    }
  });

  searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      const q = searchInput.value.trim();
      if (q) performSearch(q);
    }
  });

  searchInput.addEventListener('input', function() {
    if (searchTimeout) clearTimeout(searchTimeout);
    const q = searchInput.value.trim();
    if (q.length >= 2) {
      searchTimeout = setTimeout(function() { performSearch(q); }, 400);
    } else {
      searchLoading.style.display = 'none';
      searchResults.querySelectorAll('.lsw-search-result').forEach(function(el) { el.remove(); });
      searchEmpty.style.display = 'flex';
      searchEmpty.textContent = q.length === 0 ? 'Type to search' : 'Type at least 2 characters';
    }
  });

  async function performSearch(query) {
    const savedLang = localStorage.getItem(STORAGE_KEY);
    const targetLang = (savedLang && savedLang !== sourceLanguage) ? savedLang : '';

    searchEmpty.style.display = 'none';
    searchLoading.style.display = 'flex';

    try {
      const res = await fetch(BACKEND + '/api/multilingual-search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query: query,
          target_language: targetLang,
          limit: 20
        })
      });
      if (!res.ok) throw new Error('Search failed');
      const data = await res.json();
      displayResults(data.results || [], targetLang);
    } catch (err) {
      console.error('[LSW] Search failed:', err);
      searchLoading.style.display = 'none';
      searchEmpty.style.display = 'flex';
      searchEmpty.textContent = 'Search failed. Please try again.';
    }
  }

  const PAGE_LABELS = {
    home: 'Home', product: 'Product', collection: 'Collection',
    seo: 'SEO', other: 'Other'
  };

  function displayResults(results, targetLang) {
    searchLoading.style.display = 'none';

    // Remove old results
    searchResults.querySelectorAll('.lsw-search-result').forEach(function(el) { el.remove(); });

    if (!results.length) {
      searchEmpty.style.display = 'flex';
      searchEmpty.textContent = 'No results found';
      return;
    }

    searchEmpty.style.display = 'none';

    results.forEach(function(row) {
      const el = document.createElement('div');
      el.className = 'lsw-search-result';

      var pageLabel = PAGE_LABELS[row.page] || row.page || '';
      var langBadge = '';
      if (row.is_fallback) {
        langBadge = '<span class="lsw-search-result-fallback">' + row.display_language + ' (fallback)</span>';
      } else if (row.translated_text) {
        langBadge = '<span class="lsw-search-result-lang">' + targetLang + '</span>';
      }

      el.innerHTML = `
        <div class="lsw-search-result-translated">${escapeHtml(row.display_text)}</div>
        <div class="lsw-search-result-original">${escapeHtml(row.source_text)}</div>
        <div style="display:flex;align-items:center;gap:6px;margin-top:2px;">
          <span class="lsw-search-result-page">${pageLabel}</span>
          ${langBadge}
        </div>
      `;

      el.addEventListener('click', function() {
        closeSearch();
        if (row.page === 'product' && row.resource_id) {
          // Try to navigate to product page
          var path = window.location.pathname;
          if (path.indexOf('/products/') === -1) {
            window.location.href = '/products/' + row.resource_id;
          }
        }
      });

      searchResults.appendChild(el);
    });
  }

  function escapeHtml(str) {
    if (!str) return '';
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  function setActive(lang) {
    document.querySelectorAll('.lsw-embed-opt').forEach(function(o) {
      o.classList.toggle('active', o.dataset.lang === lang);
    });
    label.textContent = lang;
  }

  // Forward-reference — real implementation is assigned inside the overlay block below
  let syncOverlayReplacements = async function() {};

  async function handleSelect(lang) {
    dropdown.hidden = true;
    chevron.style.transform = '';
    closeSearch();

    // If the user selects the source language, reset page to original
    if (lang === sourceLanguage) {
      localStorage.removeItem(STORAGE_KEY);
      setActive(sourceLanguage);
      location.reload();
      return;
    }

    setActive(lang);
    localStorage.setItem(STORAGE_KEY, lang);
    await runTranslation(lang);
    // Apply any manually saved/edited translations for this language on top
    await syncOverlayReplacements();

    // Re-apply currency after overlay sync (overlay sync may reset prices)
    if (window.__lswCurrencyReapply) {
      window.__lswCurrencyReapply();
    }

    if (currencyEnabled) {
      console.log('[LSW] Currency conversion is ENABLED. Running currency logic...');
      if (currencyApiKey) {
        console.log('[LSW] Currency API Key loaded successfully. Ready to convert.');
        
        // Simple language to currency mapping
        const currencyMap = {
          'Hindi': 'INR', 'Spanish': 'EUR', 'French': 'EUR', 'German': 'EUR', 
          'Japanese': 'JPY', 'Italian': 'EUR', 'Portuguese': 'BRL', 'Chinese': 'CNY',
          'Korean': 'KRW', 'Arabic': 'AED', 'English': 'USD'
        };
        const targetCurrency = currencyMap[lang] || 'USD';
        
        try {
          // Detect Shopify's base currency, fallback to USD
          const baseCurrency = (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'USD';
          
          const res = await fetch(`https://v6.exchangerate-api.com/v6/${currencyApiKey}/latest/${baseCurrency}`);
          if (res.ok) {
            const data = await res.json();
            const rate = data.conversion_rates[targetCurrency];
            
          if (rate && targetCurrency !== baseCurrency) {
              console.log(`[LSW] Converting prices from ${baseCurrency} to ${targetCurrency} at rate ${rate}`);
              
              const symbols = { 'INR': '₹', 'EUR': '€', 'JPY': '¥', 'BRL': 'R$', 'CNY': '¥', 'KRW': '₩', 'AED': 'د.إ', 'USD': '$', 'GBP': '£', 'CAD': '$' };
              const newSymbol = symbols[targetCurrency] || targetCurrency + ' ';
              
              const PRICE_SELECTORS = [
                '.money', '.price', '.price-item', '.product__price',
                '.product-price', '[data-product-price]', '[data-regular-price]',
                '[data-sale-price]', '.amount', '.price__regular',
                '.price__sale', '.price__compare', '.price--on-sale',
                '.cart-item__price', '.cart__price', '.order-summary__price',
                'span[class*="price"]', 'span[class*="money"]', 'span[class*="amount"]'
              ].join(', ');

              function applyConversion() {
                // Guard: prevent re-entrant calls from MutationObserver triggered by our own DOM changes
                if (window.__lswCurrencyApplying) return;
                window.__lswCurrencyApplying = true;

                try {
                  const priceEls = document.querySelectorAll(PRICE_SELECTORS);
                  const priceElsArray = Array.from(priceEls);
                  const dedupedEls = priceElsArray.filter(el =>
                    !priceElsArray.some(other => other !== el && other.contains(el))
                  );
                  console.log(`[LSW] Applying currency to ${dedupedEls.length} unique price elements`);

                  dedupedEls.forEach(el => {
                    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
                    let node;
                    while ((node = walker.nextNode())) {
                      // Store original on the TEXT NODE itself (not the element) to avoid stale parent textContent
                      if (node._lswOriginal === undefined) {
                        node._lswOriginal = node.nodeValue;
                      }
                      const originalNodeText = node._lswOriginal;

                      // Only process text nodes that actually contain a number
                      const match = originalNodeText.match(/([\d,]+(?:\.\d+)?)/);
                      if (match && match[1]) {
                        const numValue = parseFloat(match[1].replace(/,/g, ''));
                        if (!isNaN(numValue) && numValue > 0) {
                          const convertedValue = (numValue * rate).toFixed(2);
                          let newText = originalNodeText.replace(match[1], convertedValue);
                          newText = newText.replace(/[\$€£¥₹₩]|(?:Rs\.?\s*|rs\s*|USD|EUR|GBP|INR|AED|CAD)/ig, '').trim();
                          node.nodeValue = `${newSymbol}${newText}`;
                        }
                      }
                    }
                  });
                } finally {
                  window.__lswCurrencyApplying = false;
                }
              }

              // Run now and register for re-apply after overlay sync
              applyConversion();
              window.__lswCurrencyReapply = applyConversion;
            } else if (targetCurrency === baseCurrency) {
              console.log(`[LSW] Target currency is the same as base currency (${baseCurrency}). No conversion needed.`);
            }
          } else {
            console.error('[LSW] ExchangeRate API returned an error:', await res.text());
          }
        } catch (err) {
          console.error('[LSW] Currency API failed:', err);
        }
      } else {
        console.log('[LSW] Warning: Currency conversion is enabled but no API key was found in settings.');
      }
    }
  }

  // Reference to the language-switcher root element
  const lswRoot = document.getElementById('lsw-embed');

  async function runTranslation(lang) {
    const walker = document.createTreeWalker(
      document.body, NodeFilter.SHOW_TEXT,
      { acceptNode(n) {
        const tag = n.parentElement && n.parentElement.tagName;
        if (!n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
        if (['SCRIPT','STYLE','NOSCRIPT','TEMPLATE'].includes(tag)) return NodeFilter.FILTER_REJECT;
        if (lswRoot && lswRoot.contains(n.parentElement)) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }}
    );

    const nodes = [], texts = [];
    let n;
    while ((n = walker.nextNode())) { 
      nodes.push(n); 
      
      if (n.__lsw_orig_node_text === undefined) {
        n.__lsw_orig_node_text = n.nodeValue;
      }
      texts.push(n.__lsw_orig_node_text.trim()); 
      
      // Capture original text before translation so overlay replacements can match it later
      let p = n.parentElement;
      while (p && p !== document.documentElement) {
        if (p.__lsw_orig_text !== undefined) break; // Already captured for this element and its ancestors
        p.__lsw_orig_text = p.textContent;
        p = p.parentElement;
      }
    }

    console.log(`[LSW] Translating ${texts.length} nodes to ${lang}`);
    status.style.display = 'flex';
    statusTxt.textContent = `Translating...`;

    try {
      const res = await fetch(`${BACKEND}/bulk-translate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: texts, target_language: lang })
      });
      if (res.ok) {
        const data = await res.json();
        const translations = data.translations;
        for (let i = 0; i < nodes.length; i++) {
          if (translations && translations[i]) {
            const orig = nodes[i].__lsw_orig_node_text;
            const trimmed = orig.trim();
            if (trimmed) {
              nodes[i].nodeValue = orig.replace(trimmed, translations[i]);
            } else {
              nodes[i].nodeValue = translations[i];
            }
          }
        }
      }
    } catch(e) {
      console.error(`[LSW] Bulk translation failed:`, e);
    }

    status.style.display = 'none';
    console.log('[LSW] Done!');
  }

  const savedLang = localStorage.getItem(STORAGE_KEY);
  
  if (savedLang && savedLang !== sourceLanguage) {
    setActive(savedLang);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        runTranslation(savedLang);
      });
    } else {
      runTranslation(savedLang);
    }
  } else {
    // 4. Otherwise, stick to the original source language
    setActive(sourceLanguage);
  }


  // Apply saved overlay replacements so edited translations appear on the storefront
  if (!window.__multilingualOverlayLoaded) {
    window.__multilingualOverlayLoaded = true;

    const overlayBackend = 'https://shopify-multilanguage-convertor.onrender.com';
    const currentUrl = (window.location.origin + window.location.pathname + window.location.search).replace(/\/$/, '');

    function normalizeText(value) {
      return (value || '').replace(/\s+/g, ' ').trim();
    }

    function matchesTarget(element, originalText, elementTag) {
      if (!originalText) return false;
      const normalizedOriginal = normalizeText(originalText);
      const upperTag = (elementTag || '').toUpperCase();

      // Use the captured original text if available (so we can match even after auto-translation)
      const currentText = element.__lsw_orig_text !== undefined ? element.__lsw_orig_text : (element.textContent || '');

      if (['INPUT', 'TEXTAREA'].includes(upperTag)) {
        const candidateText = normalizeText(element.value || element.placeholder || '');
        return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
      }

      if (upperTag === 'BUTTON' || element.tagName === 'BUTTON') {
        const candidateText = normalizeText(element.__lsw_orig_text !== undefined ? element.__lsw_orig_text : (element.textContent || element.value || ''));
        return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
      }

      const candidateText = normalizeText(currentText);
      return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
    }

    function applyTextToElement(element, newText, elementTag) {
      const tag = (element.tagName || elementTag || '').toUpperCase();

      if (tag === 'INPUT' || tag === 'TEXTAREA') {
        if (element.type === 'submit' || element.type === 'button') {
          element.value = newText;
        } else if (element.placeholder && element.placeholder.trim() !== '') {
          element.placeholder = newText;
        } else {
          element.value = newText;
        }
        return;
      }

      // Safe replacement: instead of overwriting textContent (which destroys child elements like SVGs and refs),
      // we only replace the text nodes.
      const walker = document.createTreeWalker(element, NodeFilter.SHOW_TEXT, null, false);
      const textNodes = [];
      let n;
      while (n = walker.nextNode()) {
        if (n.nodeValue.trim().length > 0) {
          textNodes.push(n);
        }
      }

      if (textNodes.length > 0) {
        textNodes[0].nodeValue = newText;
        // If there are multiple text parts, clear the others to avoid duplicated text
        for (let i = 1; i < textNodes.length; i++) {
          textNodes[i].nodeValue = '';
        }
      } else {
        // If no text nodes exist, safely append a text node
        element.appendChild(document.createTextNode(newText));
      }
    }

    function applyReplacements(replacements) {
      if (!Array.isArray(replacements) || !replacements.length) return;

      replacements.forEach(function(item) {
        const originalText = item.original_text;
        const newText = item.new_text;
        const selector = item.selector;
        const elementTag = item.element_tag;
        const isTranslation = item.is_translation;

        if (!newText) return;

        // STRICT: Selector is REQUIRED to prevent global replacements affecting all products
        if (!selector) {
          console.warn('[LSW] Skipping replacement without selector:', originalText);
          return;
        }

        try {
          const matchingElements = Array.from(document.querySelectorAll(selector)).filter(function(el) {
            return matchesTarget(el, originalText, elementTag);
          });

          if (matchingElements.length) {
            matchingElements.forEach(function(el) { applyTextToElement(el, newText, elementTag); });
            console.log('[LSW] Applied edit to', matchingElements.length, 'element(s) via', selector);
          }
        } catch(e) {
          console.warn('[LSW] Invalid selector, skipping:', selector, e);
        }
      });
    }

    // Real implementation — also assigned to the outer-scope let for handleSelect to use
    syncOverlayReplacements = async function() {
      try {
        const requestUrl = new URL(`${overlayBackend}/overlay/replacements`);
        requestUrl.searchParams.set('url', currentUrl);

        // KEY FIX: pass the selected language so translated edits are fetched and applied
        const selectedLang = localStorage.getItem(STORAGE_KEY);
        if (selectedLang && selectedLang !== sourceLanguage) {
          requestUrl.searchParams.set('target_language', selectedLang);
        }

        const res = await fetch(requestUrl.toString());
        if (!res.ok) return;
        const data = await res.json();
        const replacements = Array.isArray(data && data.replacements) ? data.replacements : [];
        if (replacements.length) {
          console.log('[LSW] Applying overlay replacements:', replacements.length, 'lang:', selectedLang || 'base');
          applyReplacements(replacements);
          // Re-apply currency conversion after overlay resets prices
          if (window.__lswCurrencyReapply) {
            window.__lswCurrencyReapply();
          }
        }
      } catch (e) {
        console.error('[LSW] Failed to apply overlay replacements:', e);
      }
    };

    syncOverlayReplacements();
    setInterval(syncOverlayReplacements, 5000);
    window.addEventListener('focus', syncOverlayReplacements);
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) {
        syncOverlayReplacements();
      }
    });
    const observer = new MutationObserver(function() {
      syncOverlayReplacements();
    });
    observer.observe(document.body || document.documentElement, { childList: true, subtree: true, characterData: true });
  }

})();
</script>

