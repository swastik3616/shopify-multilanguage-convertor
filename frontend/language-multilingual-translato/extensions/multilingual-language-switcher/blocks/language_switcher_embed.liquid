<div id="lsw-embed" translate="no" class="notranslate" style="position:fixed;bottom:24px;right:24px;z-index:99999;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
  <button id="lsw-embed-btn" 
  style="display:flex;align-items:center;gap:8px;padding:12px 20px;
  background:linear-gradient(135deg,#1a1a2e,#16213e);
  color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:14px;font-weight:600;
  box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.2s ease;">
    <svg width="16" height="16" 
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" 
    cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 
    10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    <span id="lsw-embed-label">Loading...</span>
    <svg id="lsw-embed-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform 0.2s ease;"><polyline points="6 9 12 15 18 9"/></svg>
  </button>

  <!-- Dropdown -->
  <div id="lsw-embed-dropdown" hidden style="position:absolute;
  bottom:calc(100% + 12px);right:0;background:#fff;border-radius:16px;
  box-shadow:0 8px 40px rgba(0,0,0,0.15);overflow:hidden;min-width:200px;
  border:1px solid rgba(0,0,0,0.06);">
    <div style="padding:12px 16px;background:#f8f9fa;border-bottom:1px solid #eee;
    font-size:11px;font-weight:700;color:#888;letter-spacing:0.08em;text-transform:uppercase;">Select Language</div>
    <div id="lsw-embed-options"></div>
  </div>

  <!-- Status bar -->
  <div id="lsw-embed-status" hidden style="position:fixed;bottom:80px;right:24px;
  background:linear-gradient(135deg,#1a1a2e,#16213e);color:#fff;padding:12px 20px;border-radius:12px;
  font-size:13px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,0.2);display:none;
  align-items:center;gap:10px;min-width:200px;z-index:99999;">
    <div id="lsw-embed-spinner" style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);
    border-top-color:#fff;border-radius:50%;animation:lswSpin 0.75s linear infinite;flex-shrink:0;"></div>
    <span id="lsw-embed-status-text">Translating...</span>
  </div>
</div>

<style>
  @keyframes lswSpin { to { transform: rotate(360deg); } }
  #lsw-embed-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
  #lsw-embed-btn:active { transform: scale(0.97); }
  .lsw-embed-opt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    cursor: pointer;
    font-size: 14px;
    color: #222;
    transition: background 0.15s;
    border-bottom: 1px solid #f0f0f0;
  }
  .lsw-embed-opt:last-child { border-bottom: none; }
  .lsw-embed-opt:hover { background: #f3f4f6; }
  .lsw-embed-opt.active { background: #eef4ff; color: #0057b8; font-weight: 600; }
  .lsw-embed-opt-flag { font-size: 18px; }
  .lsw-embed-opt-name { flex: 1; }
  .lsw-embed-opt-check { color: #0057b8; font-size: 16px; display: none; }
  .lsw-embed-opt.active .lsw-embed-opt-check { display: block; }
</style>

<script>
(async function() {
  const BACKEND = 'https://shopify-multilanguage-convertor.onrender.com';
  const STORAGE_KEY = 'shopify_selected_language';

  const ALL_LANGUAGES = [
    { lang: 'English',    flag: '🇺🇸' },
    { lang: 'French',     flag: '🇫🇷' },
    { lang: 'German',     flag: '🇩🇪' },
    { lang: 'Spanish',    flag: '🇪🇸' },
    { lang: 'Hindi',      flag: '🇮🇳' },
    { lang: 'Arabic',     flag: '🇸🇦' },
    { lang: 'Japanese',   flag: '🇯🇵' },
    { lang: 'Portuguese', flag: '🇧🇷' },
    { lang: 'Marathi',    flag: '🇮🇳' },
    { lang: 'Italian',    flag: '🇮🇹' },
    { lang: 'Chinese',    flag: '🇨🇳' },
    { lang: 'Korean',     flag: '🇰🇷' }
  ];

  const btn      = document.getElementById('lsw-embed-btn');
  const dropdown = document.getElementById('lsw-embed-dropdown');
  const label    = document.getElementById('lsw-embed-label');
  const chevron  = document.getElementById('lsw-embed-chevron');
  const status   = document.getElementById('lsw-embed-status');
  const statusTxt = document.getElementById('lsw-embed-status-text');
  const optCont  = document.getElementById('lsw-embed-options');

  let sourceLanguage = 'English';
  let activeLanguages = ALL_LANGUAGES;

  try {
    const res = await fetch(`${BACKEND}/get-languages`);
    if (res.ok) {
      const data = await res.json();
      if (data.source) {
        sourceLanguage = data.source;
      }
      const selectedLangs = [data.source, ...(data.targets || [])].filter(Boolean);
      if (selectedLangs.length > 0) {
        activeLanguages = ALL_LANGUAGES.filter(item => selectedLangs.includes(item.lang));
      }
    }
  } catch (e) {
    console.error('[LSW] Failed to fetch configured languages:', e);
  }

  // Build dropdown
  activeLanguages.forEach(function(item) {
    const el = document.createElement('div');
    el.className = 'lsw-embed-opt';
    el.dataset.lang = item.lang;
    el.innerHTML = `
      <span class="lsw-embed-opt-flag">${item.flag}</span>
      <span class="lsw-embed-opt-name">${item.lang}</span>
      <span class="lsw-embed-opt-check">✓</span>
    `;
    el.addEventListener('click', function(e) {
      e.stopPropagation();
      handleSelect(item.lang);
    });
    optCont.appendChild(el);
  });

  // Toggle dropdown
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    const open = !dropdown.hidden;
    dropdown.hidden = open;
    chevron.style.transform = open ? '' : 'rotate(180deg)';
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#lsw-embed')) {
      dropdown.hidden = true;
      chevron.style.transform = '';
    }
  });

  function setActive(lang) {
    document.querySelectorAll('.lsw-embed-opt').forEach(function(o) {
      o.classList.toggle('active', o.dataset.lang === lang);
    });
    label.textContent = lang;
  }

  // Forward-reference — real implementation is assigned inside the overlay block below
  let syncOverlayReplacements = async function() {};

  async function handleSelect(lang) {
    dropdown.hidden = true;
    chevron.style.transform = '';

    // If the user selects the source language, reset page to original
    if (lang === sourceLanguage) {
      localStorage.removeItem(STORAGE_KEY);
      setActive(sourceLanguage);
      location.reload();
      return;
    }

    setActive(lang);
    localStorage.setItem(STORAGE_KEY, lang);
    await runTranslation(lang);
    // Apply any manually saved/edited translations for this language on top
    await syncOverlayReplacements();
  }

  // Reference to the language-switcher root element
  const lswRoot = document.getElementById('lsw-embed');

  async function runTranslation(lang) {
    const walker = document.createTreeWalker(
      document.body, NodeFilter.SHOW_TEXT,
      { acceptNode(n) {
        const tag = n.parentElement && n.parentElement.tagName;
        if (!n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
        if (['SCRIPT','STYLE','NOSCRIPT','TEMPLATE'].includes(tag)) return NodeFilter.FILTER_REJECT;
        if (lswRoot && lswRoot.contains(n.parentElement)) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }}
    );

    const nodes = [], texts = [];
    let n;
    while ((n = walker.nextNode())) { nodes.push(n); texts.push(n.nodeValue.trim()); }

    console.log(`[LSW] Translating ${texts.length} nodes to ${lang}`);
    status.style.display = 'flex';
    statusTxt.textContent = `Translating...`;

    try {
      const res = await fetch(`${BACKEND}/bulk-translate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texts: texts, target_language: lang })
      });
      if (res.ok) {
        const data = await res.json();
        const translations = data.translations;
        for (let i = 0; i < nodes.length; i++) {
          if (translations && translations[i]) {
            nodes[i].nodeValue = translations[i];
          }
        }
      }
    } catch(e) {
      console.error(`[LSW] Bulk translation failed:`, e);
    }

    status.style.display = 'none';
    console.log('[LSW] Done!');
  }

  // Always start in the source language on fresh page load
  localStorage.removeItem(STORAGE_KEY);
  setActive(sourceLanguage);

  // Apply saved overlay replacements so edited translations appear on the storefront
  if (!window.__multilingualOverlayLoaded) {
    window.__multilingualOverlayLoaded = true;

    const overlayBackend = 'https://shopify-multilanguage-convertor.onrender.com';
    const currentUrl = (window.location.origin + window.location.pathname + window.location.search).replace(/\/$/, '');

    function normalizeText(value) {
      return (value || '').replace(/\s+/g, ' ').trim();
    }

    function matchesTarget(element, originalText, elementTag) {
      if (!originalText) return false;
      const normalizedOriginal = normalizeText(originalText);
      const upperTag = (elementTag || '').toUpperCase();

      if (['INPUT', 'TEXTAREA'].includes(upperTag)) {
        const candidateText = normalizeText(element.value || element.placeholder || '');
        return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
      }

      if (upperTag === 'BUTTON' || element.tagName === 'BUTTON') {
        const candidateText = normalizeText(element.textContent || element.value || '');
        return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
      }

      const candidateText = normalizeText(element.textContent || '');
      return candidateText === normalizedOriginal || candidateText.includes(normalizedOriginal);
    }

    function applyTextToElement(element, newText, elementTag) {
      const upperTag = (elementTag || '').toUpperCase();

      if (['INPUT', 'TEXTAREA'].includes(upperTag)) {
        element.value = newText;
        return;
      }

      if (upperTag === 'BUTTON' || element.tagName === 'BUTTON') {
        element.textContent = newText;
        return;
      }

      if (element.tagName === 'INPUT') {
        element.value = newText;
        return;
      }

      if (element.placeholder !== undefined) {
        element.placeholder = newText;
        return;
      }

      element.textContent = newText;
    }

    function applyReplacements(replacements) {
      if (!Array.isArray(replacements) || !replacements.length) return;

      replacements.forEach(function(item) {
        const originalText = item.original_text;
        const newText = item.new_text;
        const selector = item.selector;
        const elementTag = item.element_tag;

        if (!newText) return;

        // STRICT: Selector is REQUIRED to prevent global replacements affecting all products
        if (!selector) {
          console.warn('[LSW] Skipping replacement without selector:', originalText);
          return;
        }

        try {
          const matchingElements = Array.from(document.querySelectorAll(selector)).filter(function(el) {
            return matchesTarget(el, originalText, elementTag);
          });
          if (matchingElements.length) {
            matchingElements.forEach(function(el) { applyTextToElement(el, newText, elementTag); });
          }
        } catch(e) {
          console.warn('[LSW] Invalid selector, skipping:', selector, e);
        }
      });
    }

    // Real implementation — also assigned to the outer-scope let for handleSelect to use
    syncOverlayReplacements = async function() {
      try {
        const requestUrl = new URL(`${overlayBackend}/overlay/replacements`);
        requestUrl.searchParams.set('url', currentUrl);

        // KEY FIX: pass the selected language so translated edits are fetched and applied
        const selectedLang = localStorage.getItem(STORAGE_KEY);
        if (selectedLang && selectedLang !== sourceLanguage) {
          requestUrl.searchParams.set('target_language', selectedLang);
        }

        const res = await fetch(requestUrl.toString());
        if (!res.ok) return;
        const data = await res.json();
        const replacements = Array.isArray(data && data.replacements) ? data.replacements : [];
        if (replacements.length) {
          console.log('[LSW] Applying overlay replacements:', replacements.length, 'lang:', selectedLang || 'base');
          applyReplacements(replacements);
        }
      } catch (e) {
        console.error('[LSW] Failed to apply overlay replacements:', e);
      }
    };

    syncOverlayReplacements();
    setInterval(syncOverlayReplacements, 5000);
    window.addEventListener('focus', syncOverlayReplacements);
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) {
        syncOverlayReplacements();
      }
    });
    const observer = new MutationObserver(function() {
      syncOverlayReplacements();
    });
    observer.observe(document.body || document.documentElement, { childList: true, subtree: true, characterData: true });
  }

})();
</script>

{% schema %}
{
  "name": "Language Switcher Global",
  "target": "body",
  "settings": []
}
{% endschema %}
